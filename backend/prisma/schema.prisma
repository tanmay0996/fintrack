generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  VIEWER
  ANALYST
  ADMIN
}

enum RecordType {
  INCOME
  EXPENSE
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         Role      @default(VIEWER)
  isActive     Boolean   @default(true)
  refreshToken String?

  records   FinancialRecord[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // LOGIN | LOGOUT | CREATE | UPDATE | DELETE
  resource   String   // USER | RECORD
  resourceId String?
  details    Json?
  ipAddress  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model FinancialRecord {
  id        String     @id @default(cuid())
  amount    Float
  type      RecordType
  category  String
  date      DateTime
  notes     String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([createdById])
  @@index([isDeleted])
}
